# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Generate secrets: openssl rand -base64 32

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ailawyer
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=ai_lawyer
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── FastAPI backend ───────────────────────────────────────────────────────────
# Inside Docker: postgres/redis hostnames are service names
DATABASE_URL=postgresql+asyncpg://ailawyer:changeme_in_production@postgres:5432/ai_lawyer
REDIS_URL=redis://redis:6379
DEBUG=false
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Auth (NextAuth + FastAPI JWT) ─────────────────────────────────────────────
# Must be identical in both frontend and backend
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Next.js frontend ──────────────────────────────────────────────────────────
# Public — baked into the Next.js bundle at build time
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# ── AWS S3 — document storage (Phase 2) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=ai-lawyer-docs

# ── SSLCommerz payment gateway ────────────────────────────────────────────────
# Sandbox creds (testbox / qwerty) work on sandbox.sslcommerz.com
# Set SSLCOMMERZ_SANDBOX=false and use real creds in production
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWORD=qwerty
SSLCOMMERZ_SANDBOX=true

# Public-facing URLs (SSLCommerz needs these for callbacks)
# In production: BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
